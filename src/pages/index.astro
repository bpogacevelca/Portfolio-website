---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-5xl font-bold">Belina Pogace-Velca</div>
    <div class="text-3xl py-3 font-bold">BSc Neuroscience student</div>
    <div class="py-2">
      <text class="text-lg">  I have a strong interest in neurotechnology, software engineering, child development, and cognitive neuroscience. I am particularly interested in how brain-computer interfaces, machine learning, and digital technologies can advance neuroscience research, improve healthcare, and support children's cognitive development and learning.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn bg-{EFE6DD} text-black border border-gray-300" href="https://www.linkedin.com/in/belina-pogace-velca-a94451314" target="_blank"> Let's connect!</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Recent Projects </div>
  </div>

 <HorizontalCard
    title="Personal Portfolio Website"
    class="btn bg-{EFE6DD} text-black border border-gray-300"
    img="/P.png"
    desc="Designed and developed a responsive personal portfolio website using Astro, HTML, CSS, JavaScript, Git, and GitHub."
    url="https://github.com/bpogacevelca/Belina"
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Wind Turbine Data Analysis"
    class="btn bg-{EFE6DD} text-black border border-gray-300"
    img="/data analysis.png"
    desc="Analysed wind turbine sensor data using Python to identify potential equipment failures and produced recommendations to improve maintenance planning."
    url="https://github.com/bpogacevelca/wind-turbine-analysis"
  />


