    <li>Team Collaboration</li>
    <li>Communication</li>
    <li>Problem Solving</li>
    <li>Time Management</li>
    <li>Customer Service</li>
    <li>Analytical Skills</li>
    <li>Creative Problem Solving</li>
    <li>Software Development</li>
  </ul>
</BaseLayout>
